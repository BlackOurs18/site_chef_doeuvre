{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/mentions-legales",
      "regex": "^/mentions\\-legales(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/mentions\\-legales(?:/)?$"
    },
    {
      "page": "/profil",
      "regex": "^/profil(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/profil(?:/)?$"
    },
    {
      "page": "/realisations",
      "regex": "^/realisations(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/realisations(?:/)?$"
    },
    {
      "page": "/stage",
      "regex": "^/stage(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/stage(?:/)?$"
    },
    {
      "page": "/stage/amazonie-parfum",
      "regex": "^/stage/amazonie\\-parfum(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/stage/amazonie\\-parfum(?:/)?$"
    },
    {
      "page": "/stage/amazonie-parfum/rapport-final",
      "regex": "^/stage/amazonie\\-parfum/rapport\\-final(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/stage/amazonie\\-parfum/rapport\\-final(?:/)?$"
    },
    {
      "page": "/stage/amazonie-parfum/rapport-lancement",
      "regex": "^/stage/amazonie\\-parfum/rapport\\-lancement(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/stage/amazonie\\-parfum/rapport\\-lancement(?:/)?$"
    },
    {
      "page": "/stage/amazonie-parfum/veille",
      "regex": "^/stage/amazonie\\-parfum/veille(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/stage/amazonie\\-parfum/veille(?:/)?$"
    },
    {
      "page": "/stage/rcf-en-berry",
      "regex": "^/stage/rcf\\-en\\-berry(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/stage/rcf\\-en\\-berry(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}